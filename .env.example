# ── Server ────────────────────────────────────────────────────────────────────
API_PORT=3001

# ── Frontend origin (for CORS) ────────────────────────────────────────────────
# In production set this to your Netlify URL
FRONTEND_URL=http://localhost:5173

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: openai | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...your_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (only if AI_PROVIDER=ollama)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SUPPORT_EMAIL=support@nethernodes.online

# ── Razorpay (leave as REPLACE_ME to use mock/dev mode) ──────────────────────
RAZORPAY_KEY_ID=rzp_live_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# ── Exchange Rates (optional — uses fallback rates if not set) ────────────────
# Get a free key at https://openexchangerates.org
EXCHANGE_RATE_API_KEY=your_key_here
